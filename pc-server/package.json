{
  "name": "rikkahub-pc-server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run server.ts --dev",
    "start": "bun run server.ts",
    "smoke:request-chain": "bun run scripts/request-chain-smoke.ts",
    "compile": "bun build --compile --target=bun-windows-x64 server.ts --outfile ../dist/rikkahub-pc.exe && bun -e \"await Bun.write('../web-ui/src-tauri/binaries/rikkahub-server-x86_64-pc-windows-msvc.exe', Bun.file('../dist/rikkahub-pc.exe'))\"",
    "compile:linux": "bun build --compile --target=bun-linux-x64 server.ts --outfile ../dist/rikkahub-pc"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4"
  }
}
